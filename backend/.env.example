# Database (SQLite by default — swap for PostgreSQL in production)
DATABASE_URL=sqlite:///./vitalplan.db

# Environment: development | production
ENVIRONMENT=development

# Redis (optional — leave empty for in-memory rate limits)
REDIS_URL=

# Security — MUST change in production (32+ chars)
SECRET_KEY=dev-only-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Required in production; also required to register admins after the first one
ADMIN_REGISTRATION_SECRET=

# Local image upload directory (used when S3 is unset)
UPLOAD_DIR=./uploads

# Optional S3-compatible object storage (MinIO / AWS)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# Optional Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging: auto (JSON when ENVIRONMENT=production) | text | json
LOG_FORMAT=auto

# CORS
ALLOWED_HOSTS=["http://localhost:3000", "http://localhost:5173"]

# Open Food Facts user agent
OPEN_FOOD_FACTS_USER_AGENT=VitalPlan/1.0 (contact: support@vitalplan.local)

# Payments (optional — demo mode when unset)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173

# SMTP email (optional — console fallback when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vitalplan.local
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Development default false (auto-verify). Production always requires verification.
EMAIL_VERIFICATION_REQUIRED=false
# In production, set SMTP_* above so verification and password-reset emails deliver.

# Azure OpenAI (optional — demo mode used when unset)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_EMBEDDING_MODEL=
AZURE_OPENAI_TEMPERATURE=0.1
AZURE_OPENAI_MAX_TOKENS=4000

# Groq (optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=

# Azure Computer Vision
AZURE_COMPUTER_VISION_ENDPOINT=
AZURE_COMPUTER_VISION_KEY=

# External APIs
NUTRITION_API_KEY=
USDA_API_KEY=
