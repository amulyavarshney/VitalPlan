# Database
DATABASE_URL=postgresql://user:password@localhost/vitalplan

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_HOSTS=["http://localhost:3000", "http://localhost:5173"]

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=your-azure-openai-api-version
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_MODEL=your-azure-openai-model
AZURE_OPENAI_EMBEDDING_MODEL=your_embedding_deployment
AZURE_OPENAI_TEMPERATURE=0.1
AZURE_OPENAI_MAX_TOKENS=4000

# Groq
GROQ_API_KEY=your-secret-

# Azure Computer Vision
AZURE_COMPUTER_VISION_ENDPOINT=
AZURE_COMPUTER_VISION_KEY=

# External APIs
NUTRITION_API_KEY=
USDA_API_KEY=